    {
      "id": "table-Li",
      "internal_table_id": "table-Li",
      "kind": "latex_table",
      "status": "written",
      "source_ref": {
        "path": "literature/2101.05771/arxiv_source/Lux.tex",
        "start_line": 317,
        "end_line": 353,
        "caption": "Temperatures, spectral types and magnitudes of the six Li-rich stars and the remaining observed early-type runaway star candidates. Effective Temperatures $T_{\\text{eff}}$ of the Li stars and the stars in HB9 are from our parameter fits and from \\citet{Bai2019}, respectively. The spectral types of the stars in Monoceros and Vela Jr. were taken from the \\textit{Skiff} catalogue (Vo85, \\citealt{Houk1978}). Conversion between $T_{\\text{eff}}$ and SpT was done with PM13. \\textit{G, BP} and \\textit{RP} magnitudes are from \\textit{Gaia} DR2, absolute $G$ magnitudes $M_G$ were calculated from \\textit{Gaia G}, extinction and parallax and $G$ band extinctions are from the \\textit{StarHorse} catalogue \\citep{Anders2019}. The last two columns show Li equivalent widths $EW_{\\text{Li}}$ and abundances $\\log(N_{\\text{Li}})$ for the six Li-rich stars.",
        "label": "Li"
      },
      "source_path": "literature/2101.05771/arxiv_source/Lux.tex",
      "excerpt_path": "literature/2101.05771/catalog_sources/table-Li/excerpt.tex",
      "sha256": "adf76bd3cbccc10c3c4b4b4c3c40f88df3c9c8425ff5bb3cc94dcb3bd886e3e0",
      "line_count": 37,
      "error": ""
    },
    {
      "id": "table-HRD_ages",
      "internal_table_id": "table-HRD_ages",
      "kind": "latex_table",
      "status": "written",
      "source_ref": {
        "path": "literature/2101.05771/arxiv_source/Lux.tex",
        "start_line": 394,
        "end_line": 434,
        "caption": "Estimated HRD ages (see Figs.~\\ref{HRD} and \\ref{HRD_zoom}) for the six Li-rich stars, including both components of the SB2 TYC159-251-1, as well as for the remaining observed runaway star candidates in HB9, Monoceros Loop and Vela Jr. If a star is consistent with the zero-age main-sequence, only a lower limit is given in column 2. Otherwise, the values in column 2 represent the case that the star is on its pre-MS and the values in column 3 represent the case that the star is on its terminal-age- or post-MS.",
        "label": "HRD_ages"
      },
