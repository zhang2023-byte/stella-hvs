    "extractor": "agent",
    "summary": "Three LMC-origin HVSs (HVS 3, HVS 7, HVS 15) are discussed in the paper as dynamical tracers for constraining the LMC orbit. All three originate from the HVS Survey (Brown et al. 2014) and were identified as LMC-origin candidates by Han et al. (2025). The paper assumes they originated from the LMC and uses their trajectories to constrain the LMC's past orbit and present-day dynamical center."
  },
  "method_chain": [
    {
      "id": "step-01",
      "depends_on": [],
      "step_type": "input_catalog",
      "summary": "Adopt HVS Survey dataset (Brown et al. 2014) and Gaia DR3 astrometry for HVS 3, 7, and 15 from Han et al. (2025)."
    },
    {
      "id": "step-02",
      "depends_on": [
        "step-01"
      ],
      "step_type": "astrometric_calibration",
      "summary": "Transform heliocentric observations to Galactocentric coordinates using Solar phase-space parameters from Reid et al. (2019) with uncertainties increased by factor of two."
    },
    {
      "id": "step-03",
      "depends_on": [
        "step-02"
      ],
      "step_type": "velocity_calculation",
      "summary": "Compute Galactocentric velocities from observed phase-space coordinates."
    },
    {
      "id": "step-04",
      "depends_on": [
        "step-03"
      ],
      "step_type": "orbit_integration",
      "summary": "Integrate HVS orbits backward in time as test particles in evolving LMC-Milky Way potential using gala, with 10,000 Monte Carlo realizations per star."
    },
    {
      "id": "step-05",
      "depends_on": [
        "step-04"
      ],
      "step_type": "origin_assessment",
      "summary": "Assess LMC origin by evaluating which backward-integrated trajectories intersect the LMC's dynamical center within 1 kpc."
    },
    {
      "id": "step-06",
      "depends_on": [
        "step-01"
      ],
      "step_type": "reported_value_adoption",
      "summary": "Adopt heliocentric distance measurements directly from the HVS Survey dataset."
    },
    {
      "id": "step-07",
      "depends_on": [
        "step-01"
      ],
      "step_type": "reported_value_adoption",
      "summary": "Adopt heliocentric radial velocity measurements directly from the HVS Survey dataset."
    }
