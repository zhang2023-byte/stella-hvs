# Project-local DeepXiv search, DeepXiv-assisted catalog assessment, and optional LLM review configuration.
# Copy this file to stella-workspace/.env and fill in your provider values.
#
# DeepXiv API token for DeepXiv search and catalog-assessment enrichment.
# Get one with `deepxiv config` (saves to ~/.env) or register at
# https://data.rag.ac.cn/register . SDK/docs: https://github.com/DeepXiv/deepxiv_sdk
DEEPXIV_TOKEN=

# NASA ADS API token for ADS metadata/bibcode retrieval.
# Generate at https://ui.adsabs.harvard.edu/user/settings/token
# Docs: https://github.com/adsabs/adsabs-dev-api
ADS_API_TOKEN=

# LLM gateway configuration (OpenAI-compatible; URL normally ends with /v1).
# The project default is the Token Dance gateway (https://tokendance.space),
# one key for many models. Create a key at https://tokendance.space/keys.
# Verify your setup with: python scripts/check_llm_endpoint.py
#
# Benchmark model roster (ids as listed by /gateway/v1/models):
#   deepseek-v4-pro   default / main model (1M context)
#   kimi-k2.6         supplement (256K context)
#   minimax-m3        supplement (1M context)
#   mimo-v2.5-pro     supplement (1M context)
LLM_API_KEY=
LLM_BASE_URL=https://tokendance.space/gateway/v1
LLM_MODEL=deepseek-v4-pro
LLM_THINKING=
LLM_REASONING_EFFORT=
