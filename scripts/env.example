# Project-local DeepXiv and optional LLM title classifier configuration.
# Copy this file to stella-workspace/.env and fill in your provider values.
#
# DeepXiv search and brief API token.
DEEPXIV_TOKEN=

# The URL should be OpenAI-compatible and normally ends with /v1.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
